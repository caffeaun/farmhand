# FarmHand configuration — generated by `farmhand setup` on {{ .GeneratedAt }}.
# Edit freely; re-running `farmhand setup` against an existing install will
# detect this file and ask before overwriting it.

server:
  host: "{{ .Server.Host }}"            # 127.0.0.1 = local only (Cloudflare-tunnel deployments)
  port: {{ .Server.Port }}
  auth_token: "{{ .Server.AuthToken }}"
  cors_origins:
    - "*"
  dev_mode: {{ .Server.DevMode }}

database:
  path: "{{ .Database.Path }}"
  retention_days: {{ .Database.RetentionDays }}

devices:
  auto_discover: {{ .Devices.AutoDiscover }}
  poll_interval_seconds: {{ .Devices.PollIntervalSecs }}
  min_battery_percent: {{ .Devices.MinBatteryPct }}
  cleanup_between_runs: {{ .Devices.CleanupBetweenRuns }}
  wake_before_test: {{ .Devices.WakeBeforeTest }}
  adb_path: "{{ .Devices.ADBPath }}"
  # iOS simulators to manage as a fleet (macOS + full Xcode only).
  # Add UDIDs or names from `xcrun simctl list devices`. Empty disables it.
  ios_simulators: []

jobs:
  default_timeout_minutes: {{ .Jobs.DefaultTimeoutMin }}
  max_concurrent_jobs: {{ .Jobs.MaxConcurrentJobs }}
  artifact_storage_path: "{{ .Jobs.ArtifactDir }}"
  result_storage_path: "{{ .Jobs.ResultDir }}"
  log_dir: "{{ .Jobs.LogDir }}"
  max_artifact_size_mb: {{ .Jobs.MaxArtifactSizeMB }}

notifications:
  webhook_url: ""
  notify_on:
    - failure
    - completion

vision:
  provider: "{{ .Vision.Provider }}"
  api_key_env: "{{ .Vision.APIKeyEnv }}"
  base_url: "{{ .Vision.BaseURL }}"
  model: "{{ .Vision.Model }}"
  timeout_sec: {{ .Vision.TimeoutSec }}
  detail: "{{ .Vision.Detail }}"
